# Plantilla de variables de entorno para HiChapi.
# Copia este archivo a .env.local y rellena cada valor con tus claves reales.
# .env.local está gitignored — NUNCA commitees las claves reales.

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude API (Anthropic) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Mapbox (mapas en /buscar) ──────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Google Places API (New) ────────────────────────────────────────────────
# Usado por /api/enrich-zone para descubrir restaurantes en zonas sin cobertura.
# Habilitar la API "Places API (New)" en https://console.cloud.google.com.
# Costo: ~USD $0.032 por llamada con FieldMask que incluye reviews (Pro tier).
# Crédito gratis Google: USD $200/mes ≈ 6.250 llamadas.
GOOGLE_PLACES_API_KEY=

# ── Stripe (pagos) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Site / admin ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_SECRET=
ADMIN_SEED_KEY=
