# HiChapi cloud API base
HICHAPI_API_URL=https://app.hichapi.cl

# Supabase project (used for Realtime subscription)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Print server bearer token (issued by /api/print/servers — shown ONCE on creation)
PRINT_SERVER_TOKEN=

# Optional override of the printer transport. If unset, uses the values stored
# in the print_servers row.
# PRINTER_KIND=network
# PRINTER_ADDR=192.168.1.50:9100
